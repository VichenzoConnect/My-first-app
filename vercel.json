{
  "buildCommand": "BASE_PATH=/ pnpm --filter @workspace/parrot-translator run build",
  "outputDirectory": "artifacts/parrot-translator/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
